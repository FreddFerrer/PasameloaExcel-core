# App
APP_NAME=PasameloaExcel Backend
APP_VERSION=0.1.0
APP_API_V1_PREFIX=/api/v1

# Logging
APP_LOG_LEVEL=INFO
APP_LOG_JSON=true
APP_LOG_TO_FILE=false

# CORS and origin checks
# Single origin:
# APP_CORS_ALLOWED_ORIGINS=https://tu-frontend.up.railway.app
# Multiple origins (comma separated):
# APP_CORS_ALLOWED_ORIGINS=https://tu-frontend.up.railway.app,https://staging-frontend.up.railway.app
APP_CORS_ALLOWED_ORIGINS=https://tu-frontend.up.railway.app
APP_CORS_ALLOW_CREDENTIALS=false
APP_CORS_ALLOW_METHODS=GET,POST,OPTIONS
APP_CORS_ALLOW_HEADERS=*

# Extra server-side guard for Origin header
# true => blocks unsafe requests (POST/PUT/PATCH/DELETE) with missing Origin
APP_ENFORCE_ORIGIN_CHECK=true

# Rate limiting (middleware, por IP)
APP_RATE_LIMIT_ENABLED=true
APP_RATE_LIMIT_REQUESTS=120
APP_RATE_LIMIT_WINDOW_SECONDS=60
APP_RATE_LIMIT_TRUST_PROXY=true
APP_RATE_LIMIT_EXEMPT_PATHS=/api/v1/health

# Optional support email integration
APP_SUPPORT_EMAIL_ENABLED=false
APP_SUPPORT_EMAIL_TO=
APP_SUPPORT_EMAIL_FROM=
APP_SUPPORT_SMTP_HOST=
APP_SUPPORT_SMTP_PORT=587
APP_SUPPORT_SMTP_USERNAME=
APP_SUPPORT_SMTP_PASSWORD=
APP_SUPPORT_SMTP_USE_TLS=true
